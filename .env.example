# Copy to .env and fill in your values

# Postgres
POSTGRES_PASSWORD=use_a_strong_password_here

# Redis
REDIS_PASSWORD=use_a_strong_password_here

# Worker
WORKER_CONCURRENCY=10   # increase for higher throughput

# EVM RPC endpoints - replace with your own (Infura, Alchemy, etc.)
# EVM_RPC_1=https://mainnet.infura.io/v3/YOUR_KEY
# EVM_RPC_137=https://polygon-mainnet.infura.io/v3/YOUR_KEY
# EVM_RPC_42161=https://arbitrum-mainnet.infura.io/v3/YOUR_KEY
# EVM_RPC_8453=https://base-mainnet.infura.io/v3/YOUR_KEY
# EVM_RPC_10=https://optimism-mainnet.infura.io/v3/YOUR_KEY

# Solana RPC
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
